SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Database
DB_URL=jdbc:postgresql://<host>:5432/<db>
DB_USERNAME=<username>
DB_PASSWORD=<password>
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# JWT
JWT_SECRET=<base64-or-long-random-secret>
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# URLs used for email links
APP_BACKEND_BASE_URL=https://<your-koyeb-service>.koyeb.app
APP_FRONTEND_RESET_PASSWORD_URL=https://<your-frontend-domain>/reset-password

# SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<smtp-username>
MAIL_PASSWORD=<smtp-password-or-app-password>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000

# Kafka (Managed Kafka, e.g., Upstash/Confluent/Aiven)
KAFKA_BOOTSTRAP_SERVERS=<broker1:9092,broker2:9092>
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="<kafka-api-key>" password="<kafka-api-secret>";
KAFKA_SSL_ENDPOINT_IDENTIFICATION_ALGORITHM=https
